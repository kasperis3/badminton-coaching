[Unit]
Description=Baddy badminton mixer (Gunicorn)
After=network.target

[Service]
User=deploy
Group=deploy
WorkingDirectory=/var/www/baddy
Environment=SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
ExecStart=/var/www/baddy/venv/bin/gunicorn --bind 127.0.0.1:8000 --workers 1 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
